{"clock":{"calendar":{"format":{"days":"<span color='#cdd6f4'>{}</span>","months":"<span color='#cdd6f4'><b>{}</b></span>","today":"<span color='#f38ba8'><b><u>{}</u></b></span>","weekdays":"<span color='#f9e2af'><b>{}</b></span>","weeks":"<span color='#a6e3a1'><b>H{}</b></span>"},"mode":"month","mode-mon-col":3,"on-click-right":"mode","on-scroll":1,"weeks-pos":"right"},"format":" {:%H:%M}","format-alt":"📅 {:%d/%m/%Y %H:%M}","interval":60,"timezone":"Europe/Istanbul","tooltip-format":"<big>{:%Y %B}</big>\n{calendar}"},"cpu":{"format":" {usage}% {icon}","format-alt":"⚡ {usage}%","format-icons":["▁","▂","▃","▄","▅","▆","▇","█"],"interval":5,"on-click":"kitty -e btop","states":{"critical":90,"warning":70},"tooltip":true,"tooltip-format":"CPU kullanımı: {usage}%\nFrequency: {frequency} GHz"},"custom/power":{"format":"⏻","on-click":"wlogout","on-click-right":"systemctl poweroff","tooltip":true,"tooltip-format":"Güç Menüsü\nSol: wlogout\nSağ: Kapat"},"custom/temperature":{"exec":"/home/localhost/.local/bin/waybar-temperature.sh","interval":5,"on-click":"kitty -e btop","return-type":"json","tooltip":false},"gamemode":{"format":"{glyph}","format-alt":"{glyph} {count}","glyph":"🎮","hide-not-running":true,"icon-name":"input-gaming-symbolic","icon-size":16,"icon-spacing":4,"tooltip":true,"tooltip-format":"GameMode aktif: {count} oyun","use-icon":true},"height":32,"hyprland/window":{"format":"{}","max-length":50,"rewrite":{"(.*) - Brave":"🌐 $1","(.*) — Dolphin":"📁 $1","kitty":"🐱 kitty"}},"hyprland/workspaces":{"all-outputs":false,"format":"{name}","format-icons":{"1":"一","2":"二","3":"三","4":"四","5":"五","6":"六","7":"七","8":"八","active":"●","default":"○","urgent":"！"},"on-click":"activate","persistent-workspaces":{"1":[],"2":[],"3":[]},"show-special":false},"layer":"top","margin-bottom":0,"margin-top":0,"memory":{"format":" {}%","format-alt":"🧠 {used:0.1f}G / {total:0.1f}G","interval":10,"on-click":"kitty -e btop","states":{"critical":90,"warning":70},"tooltip":true,"tooltip-form